{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy/pc-header-top-bar",
	"version": "0.1.4",
	"title": "[Header] Top Bar",
	"category": "ai-zippy",
	"icon": "heading",
	"description": "Top bar information and social links",
	"supports": {
		"html": false,
		"anchor": true
	},
	"attributes": {
		"locationText": {
			"type": "string",
			"default": "Pawland Club Singapore"
		},
		"emailText": {
			"type": "string",
			"default": "hello@pawlandclub.com"
		},
		"socialLinks": {
			"type": "array",
			"default": [
				{
					"platform": "facebook",
					"url": "#",
					"icon": "fab fa-facebook-f"
				},
				{
					"platform": "instagram",
					"url": "#",
					"icon": "fab fa-instagram"
				},
				{
					"platform": "tiktok",
					"url": "#",
					"icon": "fab fa-tiktok"
				}
			]
		},
		"bgColor": {
			"type": "string",
			"default": "#2d5a27"
		},
		"textColor": {
			"type": "string",
			"default": "#f4efdf"
		}
	},
	"textdomain": "ai-zippy",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./style-index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
