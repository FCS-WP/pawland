{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy/pc-page-hero",
	"version": "1.0.3",
	"title": "[Page] Hero Section",
	"category": "ai-zippy",
	"icon": "cover-image",
	"description": "A premium hero banner with brand green background and rounded corners.",
	"attributes": {
		"title": {
			"type": "string",
			"source": "html",
			"selector": "h1",
			"default": "Page Title"
		},
		"description": {
			"type": "string",
			"source": "html",
			"selector": ".page-hero__desc",
			"default": "Add a short description here to welcome your visitors."
		}
	},
	"supports": {
		"anchor": true,
		"html": false,
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"textdomain": "ai-zippy-child",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./editor.scss",
	"style": "file:./style.scss",
	"render": "file:./render.php"
}
