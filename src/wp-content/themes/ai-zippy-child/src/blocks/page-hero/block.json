{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy/pc-page-hero",
	"version": "1.0.9",
	"title": "[Page] Hero Section",
	"category": "ai-zippy",
	"icon": "cover-image",
	"description": "A premium hero banner with brand green background and rounded corners.",
	"attributes": {
		"title": {
			"type": "string",
			"default": "Page Title"
		},
		"description": {
			"type": "string",
			"default": "Add a short description here to welcome your visitors."
		},
		"heroBackgroundColor": {
			"type": "string",
			"default": "#2d5a27"
		},
		"outerBackgroundColor": {
			"type": "string",
			"default": "#ffffff"
		}
	},
	"supports": {
		"align": ["wide", "full"],
		"anchor": true,
		"html": false,
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"textdomain": "ai-zippy-child",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
