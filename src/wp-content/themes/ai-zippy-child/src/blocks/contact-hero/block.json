{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy/contact-hero",
	"version": "1.0.0",
	"title": "[Contact Us] Hero Section",
	"category": "ai-zippy",
	"icon": "cover-image",
	"description": "Hero section for Contact Us page with title and banner image.",
	"keywords": ["contact", "hero", "banner"],
	"supports": {
		"html": false,
		"align": ["wide", "full"],
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"text": true,
			"background": true,
			"link": true
		}
	},
	"attributes": {
		"title": {
			"type": "string",
			"default": "Contact Us"
		},
		"mediaId": {
			"type": "number",
			"default": 0
		},
		"mediaUrl": {
			"type": "string",
			"default": ""
		}
	},
	"textdomain": "ai-zippy",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
