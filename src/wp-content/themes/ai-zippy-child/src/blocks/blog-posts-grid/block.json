{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy/pc-blog-posts-grid",
	"version": "1.0.3",
	"title": "[Blog] Posts Grid",
	"category": "ai-zippy",
	"icon": "grid-view",
	"description": "A grid of the latest blog posts with premium card design.",
	"attributes": {
		"count": {
			"type": "number",
			"default": 3
		},
		"category": {
			"type": "string",
			"default": ""
		},
		"bgColor": {
			"type": "string",
			"default": "transparent"
		}
	},
	"supports": {
		"anchor": true,
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./style-index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
